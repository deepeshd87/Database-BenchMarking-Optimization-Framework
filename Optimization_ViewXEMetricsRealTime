CREATE PROCEDURE [dbo].[Optimization_ViewXEMetricsRealTime]
    @TopN INT = 20
AS
BEGIN
    SET NOCOUNT ON;
    
    -- Get latest metrics from XE tables

PRINT '===== TOP SLOW QUERIES (Last Hour) =====';
SELECT TOP (@TopN)
    EventTimeUTC,
    EventType,
    DatabaseName,
    DurationMS,
    CPUTimeMS,
    LogicalReadsPages,
    PhysicalReadsPages,
    RowsAffected,
    CASE
        WHEN DurationMS > 5000 THEN 'CRITICAL'
        WHEN DurationMS > 1000 THEN 'HIGH'
        WHEN DurationMS > 100  THEN 'MEDIUM'
        ELSE 'LOW'
    END AS Duration_Priority,
    CASE
        WHEN LogicalReadsPages > 10000 THEN 'HIGH_IO'
        WHEN LogicalReadsPages > 1000  THEN 'MEDIUM_IO'
        ELSE 'LOW_IO'
    END AS IO_Status
FROM dbo.XE_QueryPerformanceMetrics
WHERE EventTimeUTC >= DATEADD(HOUR, -1, SYSUTCDATETIME())
ORDER BY DurationMS DESC;

-- Lock contention summary
PRINT '';
PRINT '===== LOCK CONTENTION SUMMARY (Last Hour) =====';
SELECT
    COUNT(*)                          AS ContentionEvents,
    SUM(CASE WHEN EventType = 'lock_deadlock' THEN 1 ELSE 0 END) AS DeadlockEvents,
    SUM(CASE WHEN EventType = 'lock_timeout'  THEN 1 ELSE 0 END) AS TimeoutEvents,
    COUNT(DISTINCT SessionID)         AS DistinctSessionCount,
    COUNT(DISTINCT DatabaseName)      AS DatabasesAffected
FROM dbo.XE_LockContentions
WHERE EventTimeUTC >= DATEADD(HOUR, -1, SYSUTCDATETIME());

-- Memory spill summary
PRINT '';
PRINT '===== MEMORY SPILL SUMMARY (Last Hour) =====';
SELECT
    COUNT(*)                                                     AS SpillEvents,
    SUM(CASE WHEN SpillType = 'sort_warning' THEN 1 ELSE 0 END)  AS SortSpills,
    SUM(CASE WHEN SpillType = 'hash_warning' THEN 1 ELSE 0 END)  AS HashSpills,
    COUNT(DISTINCT DatabaseName)                                 AS DatabasesAffected
FROM dbo.XE_MemorySpills
WHERE EventTimeUTC >= DATEADD(HOUR, -1, SYSUTCDATETIME());
END;

